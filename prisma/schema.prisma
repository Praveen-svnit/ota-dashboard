generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Property {
  id          String  @id
  name        String
  city        String?
  fhLiveDate  String?   // stored as ISO string "YYYY-MM-DD"
  fhStatus    String?
  syncedAt    String    // ISO timestamp

  otaListings OtaListing[]
}

model OtaListing {
  id         Int     @id @default(autoincrement())
  propertyId String
  ota        String
  status     String?
  subStatus  String?
  liveDate   String?   // stored as ISO string "YYYY-MM-DD"
  otaId      String?
  syncedAt   String    // ISO timestamp

  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, ota])
  @@index([ota])
  @@index([subStatus])
}
